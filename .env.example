# .env.example
# Copiar como .env.local para desarrollo local
# En Vercel: Settings → Environment Variables

# ── Google Sheets ──────────────────────────────────────────────────────────────
# JSON completo de la Service Account key (una sola línea)
# Obtener en: Google Cloud Console → IAM → Service Accounts → Crear clave JSON
# Compartir el Spreadsheet con el email de la SA (solo lectura)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"tu-sa@tu-proyecto.iam.gserviceaccount.com"}

# ID del Google Spreadsheet (el largo entre /d/ y /edit en la URL)
SPREADSHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# ── Metabase ───────────────────────────────────────────────────────────────────
METABASE_BASE_URL=https://metabase.tuempresa.com
METABASE_USERNAME=admin@tuempresa.com
METABASE_PASSWORD=tu_password_metabase
METABASE_QUESTION_ID=64

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Secreto para firmar los tokens de sesión del frontend.
# Usar un string largo y aleatorio. Ej: openssl rand -base64 32
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-32-chars-minimo

# ── Warm-up cron ──────────────────────────────────────────────────────────────
# Vercel setea CRON_SECRET automáticamente en producción.
# Para llamadas manuales desde el navegador: /api/warmUp?secret=TU_WARM_UP_SECRET
WARM_UP_SECRET=otro-secreto-para-llamadas-manuales
